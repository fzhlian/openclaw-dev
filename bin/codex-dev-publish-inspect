#!/usr/bin/env bash
set -euo pipefail

DEFAULT_REPO="/home/fzhlian/Code/codex-dev"
REPO_DIR="${1:-${CODEX_DEV_DEFAULT_WORKDIR:-$DEFAULT_REPO}}"

case "$REPO_DIR" in
  /*) ;;
  *)
    echo "Workdir must be an absolute path: $REPO_DIR" >&2
    exit 1
    ;;
esac

if [ ! -d "$REPO_DIR" ]; then
  echo "Repo dir does not exist: $REPO_DIR" >&2
  exit 1
fi

if ! git -C "$REPO_DIR" rev-parse --show-toplevel >/dev/null 2>&1; then
  echo "Not a git repository: $REPO_DIR" >&2
  exit 1
fi

REPO_DIR="$(git -C "$REPO_DIR" rev-parse --show-toplevel)"
SKILL_DIR="$REPO_DIR/skill"

printf '## repo_status\n'
git -C "$REPO_DIR" status --short --branch

printf '\n## publish_source\n'
if [ ! -d "$SKILL_DIR" ]; then
  echo "missing $SKILL_DIR"
  exit 1
fi
printf 'path=%s\n' "$SKILL_DIR"

printf '\n## required_files\n'
for rel in SKILL.md agents/openai.yaml references/local-setup.md; do
  if [ -e "$SKILL_DIR/$rel" ]; then
    printf 'ok skill/%s\n' "$rel"
  else
    printf 'missing skill/%s\n' "$rel"
  fi
done

printf '\n## release_versions\n'
python3 - "$REPO_DIR/README.md" "$REPO_DIR/CHANGELOG.md" <<'PY'
import re
import sys
from pathlib import Path

readme = Path(sys.argv[1]).read_text(encoding="utf-8")
changelog = Path(sys.argv[2]).read_text(encoding="utf-8")

readme_match = re.search(r"clawhub publish \./skill --slug codex-dev --version ([0-9.]+)", readme)
changelog_match = re.search(r"^## \[([0-9.]+)\] - ", changelog, re.MULTILINE)

readme_version = readme_match.group(1) if readme_match else ""
changelog_version = changelog_match.group(1) if changelog_match else ""

print(f"readme_publish_example={readme_version}")
print(f"changelog_latest={changelog_version}")
print(f"version_mismatch={'yes' if readme_version and changelog_version and readme_version != changelog_version else 'no'}")
PY
